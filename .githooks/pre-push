#!/bin/sh
# Bump version by 0.1 before each push (prepares the next release number).
set -e
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

node scripts/bump-version.mjs

if ! git diff --quiet VERSION package.json; then
  git add VERSION package.json
  git commit -m "chore: bump version to $(cat VERSION | tr -d '\n')"
fi

exit 0
