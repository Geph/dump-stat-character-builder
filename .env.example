# =============================================================================
# Dump Stat — Environment Variables
# =============================================================================
# Copy to .env.local for local development:
#   cp .env.example .env.local
# =============================================================================


# -----------------------------------------------------------------------------
# MySQL (Dreamhost VPS) — required
# -----------------------------------------------------------------------------
# Option A: single connection URL (recommended)
# DATABASE_URL=mysql://USER:PASSWORD@mysql.example.com:3306/database_name

# Option B: separate fields (from Dreamhost panel → MySQL Databases)
# MYSQL_HOST=mysql.example.com
# MYSQL_USER=your_db_user
# MYSQL_PASSWORD=your_db_password
# MYSQL_DATABASE=your_db_name
# MYSQL_PORT=3306

DATABASE_URL=mysql://user:password@localhost:3306/dump_stat


# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development
PORT=3000
