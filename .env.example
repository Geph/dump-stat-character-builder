# =============================================================================
# Dump Stat — Environment Variables
# =============================================================================
# Copy to .env.local for local development:
#   cp .env.example .env.local
# =============================================================================


# -----------------------------------------------------------------------------
# MySQL — required
# -----------------------------------------------------------------------------
# Option A: single connection URL (recommended)
# DATABASE_URL=mysql://USER:PASSWORD@localhost:3306/dump_stat

# Option B: separate fields
# MYSQL_HOST=localhost
# MYSQL_USER=your_db_user
# MYSQL_PASSWORD=your_db_password
# MYSQL_DATABASE=dump_stat
# MYSQL_PORT=3306

DATABASE_URL=mysql://user:password@localhost:3306/dump_stat


# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development
PORT=3000


# -----------------------------------------------------------------------------
# OpenAI — required for PDF / pasted-text import only
# -----------------------------------------------------------------------------
# Get a key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# IMPORT_AI_MODEL=gpt-4o
