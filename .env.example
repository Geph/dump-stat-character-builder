# =============================================================================
# Dump Stat — Environment Variables
# =============================================================================
# Copy to .env.local for local development:
#   cp .env.example .env.local
# =============================================================================


# -----------------------------------------------------------------------------
# MySQL — required
# -----------------------------------------------------------------------------
# Option A: single connection URL (recommended)
# DATABASE_URL=mysql://USER:PASSWORD@localhost:3306/dump_stat

# Option B: separate fields
# MYSQL_HOST=localhost
# MYSQL_USER=your_db_user
# MYSQL_PASSWORD=your_db_password
# MYSQL_DATABASE=dump_stat
# MYSQL_PORT=3306

DATABASE_URL=mysql://user:password@localhost:3306/dump_stat


# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development
PORT=3000

# Deployment profile: hosted (MySQL + Node server) | static (IndexedDB + GitHub Pages)
NEXT_PUBLIC_DEPLOY_MODE=hosted

# Static / GitHub Pages only — repo name for project sites (e.g. /dump-stat-character-builder)
# NEXT_PUBLIC_BASE_PATH=/dump-stat-character-builder


# -----------------------------------------------------------------------------
# AI import — required for PDF / pasted-text import only
# -----------------------------------------------------------------------------
# Set ONE provider key (first match wins unless IMPORT_AI_PROVIDER is set):
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_GENERATIVE_AI_API_KEY=...   (or GOOGLE_API_KEY)

# Optional: force a provider when multiple keys are set
# IMPORT_AI_PROVIDER=openai|anthropic|google

# Optional: override default model for the selected provider
# OpenAI default: gpt-4o-mini (override in Import UI or below)
# Anthropic default: claude-sonnet-4-20250514
# Google default: gemini-2.0-flash-001
# IMPORT_AI_MODEL=gpt-4o-mini

# Optional: max characters per AI chunk (default 36000; was 42000)
# IMPORT_AI_CHUNK_SIZE=36000
