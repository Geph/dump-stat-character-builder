# =============================================================================
# Dump Stat — Sample Environment Variables
# =============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For production, set these variables in your server environment or in your
# hosting platform's secrets manager. Never commit real values to version
# control.
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase — required
# -----------------------------------------------------------------------------
# Find these in your Supabase project: Settings > API

# The public URL for your Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side keys — never expose these to the browser
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret


# -----------------------------------------------------------------------------
# Supabase Postgres (direct connection) — required for migrations / seed
# -----------------------------------------------------------------------------
# Find these in your Supabase project: Settings > Database > Connection string

POSTGRES_HOST=db.your-project-ref.supabase.co
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-database-password
POSTGRES_DATABASE=postgres

# Pooled connection (recommended for serverless / edge functions)
POSTGRES_URL=postgresql://postgres:your-database-password@db.your-project-ref.supabase.co:5432/postgres

# Prisma-compatible pooled URL (adds pgbouncer params)
POSTGRES_PRISMA_URL=postgresql://postgres:your-database-password@db.your-project-ref.supabase.co:5432/postgres?pgbouncer=true&connect_timeout=15

# Non-pooling URL (used for migrations and schema introspection)
POSTGRES_URL_NON_POOLING=postgresql://postgres:your-database-password@db.your-project-ref.supabase.co:5432/postgres


# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------

# The canonical URL your app is served from (no trailing slash).
# Used for absolute URL generation and CORS.
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Node environment — set to "production" on the server
NODE_ENV=production

# Port the Next.js server listens on (default: 3000)
PORT=3000
